{
  "handler": "handler:bolt_stresses",
  "description": "Tests pour les contraintes (traction, torsion, Von Mises) selon Annexe A",
  "test_cases": [
    {
      "name": "cas_M10_classe_10.9_contraintes_completes",
      "description": "Calcul complet des contraintes pour vis M10 classe 10.9",
      "request": {
        "vis": {
          "d": 10,
          "p": 1.5,
          "As": 58,
          "Re_min": 940,
          "quality_class": "10.9"
        },
        "assemblage": {
          "dh": 11,
          "do": 14.63,
          "Rc": 400,
          "mu_p_min": 0.15
        },
        "sollicitations": {
          "FA_max": 5000,
          "Ft_max": 2000
        },
        "serrage": {
          "mu_tot_min": 0.12,
          "mu_tot_max": 0.18,
          "precision_class": "C20"
        }
      },
      "expected": {
        "valid": true,
        "sigma_b_max": 583.0,
        "tau_b_max": 234.4,
        "sigma_b_eq": 710.5,
        "sigma_adm": 846.0,
        "margin": 135.5
      },
      "tolerance": {
        "numeric": 10.0
      }
    },
